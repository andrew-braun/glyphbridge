# Server-side delivery reads (private — never exposed to the browser)
# Local dev: run `pnpm exec supabase status -o env`, then map
# API_URL        -> SUPABASE_DELIVERY_URL
# PUBLISHABLE_KEY -> SUPABASE_DELIVERY_ANON_KEY
# (The anon key is public by nature but kept in a private var here to maintain a
#  clean server/client boundary. If a service-role key is ever needed for delivery
#  reads, only this variable changes — no public bundle risk.)
SUPABASE_DELIVERY_URL=
SUPABASE_DELIVERY_ANON_KEY=

# Browser Supabase client (optional — only needed when auth or client-side DB use is added)
# Same URL/key as above, prefixed PUBLIC_ so SvelteKit exposes them to the browser.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

{
	"name": "glyphbridge",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint . --cache --cache-location .eslintcache",
		"lint:fix": "eslint . --fix --cache --cache-location .eslintcache",
		"markdownlint": "markdownlint-cli2 --config .markdownlint.jsonc \"**/*.md\" \"#node_modules\" \"#build\" \"#.svelte-kit\"",
		"markdownlint:fix": "markdownlint-cli2 --config .markdownlint.jsonc --fix \"**/*.md\" \"#node_modules\" \"#build\" \"#.svelte-kit\"",
		"stylelint": "stylelint \"src/**/*.{css,scss,svelte}\" --cache --cache-location .stylelintcache",
		"stylelint:fix": "stylelint \"src/**/*.{css,scss,svelte}\" --fix --cache --cache-location .stylelintcache",
		"check:all": "pnpm format:check && pnpm lint && pnpm stylelint && pnpm check",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"engines": {
		"node": "24.15.0",
		"pnpm": "^10"
	},
	"packageManager": "pnpm@10.33.2",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-simple-import-sort": "^13.0.0",
		"eslint-plugin-svelte": "^3.17.1",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "^17.5.0",
		"markdownlint-cli2": "^0.22.1",
		"postcss-html": "^1.8.1",
		"postcss-scss": "^4.0.9",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"stylelint": "^17.9.0",
		"stylelint-config-html": "^1.1.0",
		"stylelint-config-recommended-scss": "^17.0.1",
		"supabase": "^2.93.0",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.59.0",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@supabase/supabase-js": "^2.101.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"bits-ui": "^2.16.5",
		"sass": "^1.98.0"
	},
	"volta": {
		"node": "24.15.0"
	}
}
